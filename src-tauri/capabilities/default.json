{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for Purrdora",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-set-fullscreen",
    "shell:allow-open",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "systemctl",
          "cmd": "systemctl",
          "args": true
        },
        {
          "name": "journalctl",
          "cmd": "journalctl",
          "args": true
        },
        {
          "name": "fwupdmgr",
          "cmd": "fwupdmgr",
          "args": true
        },
        {
          "name": "pkexec-fwupdmgr",
          "cmd": "pkexec",
          "args": [
            {
              "validator": "\\S+"
            }
          ]
        },
        {
          "name": "which",
          "cmd": "which",
          "args": true
        },
        {
          "name": "xdg-open",
          "cmd": "xdg-open",
          "args": true
        },
        {
          "name": "ptyxis",
          "cmd": "ptyxis",
          "args": true
        },
        {
          "name": "gnome-control-center",
          "cmd": "gnome-control-center",
          "args": true
        }
      ]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "systemctl",
          "cmd": "systemctl",
          "args": true
        },
        {
          "name": "journalctl",
          "cmd": "journalctl",
          "args": true
        },
        {
          "name": "fwupdmgr",
          "cmd": "fwupdmgr",
          "args": true
        },
        {
          "name": "pkexec-fwupdmgr",
          "cmd": "pkexec",
          "args": [
            {
              "validator": "\\S+"
            }
          ]
        },
        {
          "name": "which",
          "cmd": "which",
          "args": true
        },
        {
          "name": "xdg-open",
          "cmd": "xdg-open",
          "args": true
        },
        {
          "name": "ptyxis",
          "cmd": "ptyxis",
          "args": true
        },
        {
          "name": "gnome-control-center",
          "cmd": "gnome-control-center",
          "args": true
        }
      ]
    },
    "shell:allow-stdin-write",
    "fs:default",
    "fs:allow-read",
    "fs:allow-write",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "process:default",
    "process:allow-exit",
    "process:allow-restart"
  ]
}
