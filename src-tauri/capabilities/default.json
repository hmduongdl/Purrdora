{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for Purrdora",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "shell:allow-open",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "systemctl",
          "cmd": "systemctl",
          "args": true
        },
        {
          "name": "journalctl",
          "cmd": "journalctl",
          "args": true
        }
      ]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "systemctl",
          "cmd": "systemctl",
          "args": true
        },
        {
          "name": "journalctl",
          "cmd": "journalctl",
          "args": true
        }
      ]
    },
    "shell:allow-stdin-write",
    "fs:default",
    "fs:allow-read",
    "fs:allow-write",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "process:default",
    "process:allow-exit",
    "process:allow-restart"
  ]
}
