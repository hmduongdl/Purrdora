{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Fedora System Control",
  "version": "0.1.0",
  "identifier": "com.fedora.system-control",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Fedora System Control",
        "width": 800,
        "height": 600,
        "minWidth": 400,
        "minHeight": 300,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": false,
        "visibleOnAllWorkspaces": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "shell": {
      "open": true,
      "scope": [
        {
          "name": "systemctl",
          "cmd": "systemctl",
          "args": true
        },
        {
          "name": "journalctl",
          "cmd": "journalctl",
          "args": true
        }
      ]
    }
  }
}
